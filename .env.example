# 从阿里云百炼（DashScope）控制台复制 API Key，任选其一变量名：
# DASHSCOPE_API_KEY=sk-...
# BAILIAN_API_KEY=sk-...

# 可选：模型 id（默认 qwen-max，与百炼控制台「OpenAI 兼容」一致）
# LITPUBMED_LLM_MODEL=qwen-max

# 可选：非北京地域时修改（见百炼文档「OpenAI 兼容」）
# LITPUBMED_LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：HTTP API 鉴权
# LITPUBMED_API_TOKEN=your-secret
